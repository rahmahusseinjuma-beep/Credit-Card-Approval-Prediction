# Environment Configuration Example
# Copy this file to ".env" and fill in real values before running the app
# with cloud deployment or any secrets-based configuration enabled.
# Do NOT commit your actual ".env" file to GitHub - only this example file.

# --- Flask settings ---
FLASK_ENV=development
SECRET_KEY=replace-with-a-random-secret-key

# --- IBM Watson Machine Learning (optional cloud deployment) ---
# Required only if hosting the model on IBM Watson ML instead of / alongside
# the local best_model.pkl file.
IBM_WATSON_API_KEY=your-ibm-cloud-api-key-here
IBM_WATSON_URL=https://us-south.ml.cloud.ibm.com
IBM_WATSON_DEPLOYMENT_ID=your-deployment-id-here

# --- App settings ---
PORT=5000
